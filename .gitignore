# Vosk model files — download separately, place in shared/src/main/assets/asr/vosk/model/
# The placeholder 0-byte files ARE committed so the directory structure exists in the repo.
# Only the actual binary model content is ignored:
shared/src/main/assets/asr/vosk/model/am/*.mdl
shared/src/main/assets/asr/vosk/model/graph/*.fst
shared/src/main/assets/asr/vosk/model/graph/*.int
shared/src/main/assets/asr/vosk/model/graph/phones/*.int
shared/src/main/assets/asr/vosk/model/ivector/final.*
shared/src/main/assets/asr/vosk/model/ivector/*.stats
shared/src/main/assets/asr/vosk/model/ivector/*.conf
shared/src/main/assets/asr/vosk/model/conf/*.conf

# Legacy paths (no longer used)
app/src/main/assets/model-es/
wear/src/main/assets/model-es/

# sherpa-onnx / Whisper assets (keep local, do not commit large binaries)
app/src/main/assets/asr/whisper/*.onnx
app/src/main/assets/asr/moonshine/*.ort
